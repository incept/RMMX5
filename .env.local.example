# Supabase — Project Settings -> API Keys
#
# PREFERRED NAMES: NEXT_PUBLIC_SB_URL / NEXT_PUBLIC_SB_ANON_KEY /
# SB_SERVICE_ROLE_KEY. (Some hosts — Hostinger in our case — kept injecting
# stale build-time values under the standard NEXT_PUBLIC_SUPABASE_* names,
# so the code reads the SB_* names first and falls back to the old ones.)
#
# CAREFUL WITH THE KEY TYPES (mixing them up causes
# "Forbidden use of secret API key in browser" on login/register):
#   * ANON_KEY  = the PUBLISHABLE key (sb_publishable_...)
#                 or the legacy "anon" JWT. Safe for the browser.
#   * SERVICE_ROLE_KEY = the SECRET key (sb_secret_...)
#                 or the legacy "service_role" JWT. Server-only —
#                 never put this in any NEXT_PUBLIC_ variable.
NEXT_PUBLIC_SB_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SB_ANON_KEY=sb_publishable_your-key
SB_SERVICE_ROLE_KEY=sb_secret_your-key

# Shared secret for the cron endpoint (/api/cron/tick?secret=...)
CRON_SECRET=pick-a-long-random-string

# Public base URL of this deployment (used for tracking pixels / click links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NOTE: BrightData, Emailit, TextLink, Stripe and Fluent Forms keys are NOT
# env vars — admins enter them on the in-app Admin -> Integrations page and
# they are stored in the `settings` table (admin-only RLS).
