# Supabase — Project Settings -> API Keys
#
# The variable NAME tells you which key TYPE goes in it:
#   * NEXT_PUBLIC_SB_PUBLISHABLE_KEY = the PUBLISHABLE key (sb_publishable_...).
#     Safe for the browser — the ONLY kind allowed in a NEXT_PUBLIC_ variable.
#     The build fails on purpose if a secret key is pasted here.
#   * SB_SECRET_KEY = the SECRET key (sb_secret_...). Server-only.
#
# (Historical note: on our Hostinger host, editing an existing env variable
# never reached the build — only newly created variables did. That's why the
# code prefers these names and falls back to the older ones for local dev.)
NEXT_PUBLIC_SB_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SB_PUBLISHABLE_KEY=sb_publishable_your-key
SB_SECRET_KEY=sb_secret_your-key

# Shared secret for the cron endpoint (/api/cron/tick?secret=...)
CRON_SECRET=pick-a-long-random-string

# Public base URL of this deployment (used for tracking pixels / click links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NOTE: BrightData, Emailit, TextLink, Stripe and Fluent Forms keys are NOT
# env vars — admins enter them on the in-app Admin -> Integrations page and
# they are stored in the `settings` table (admin-only RLS).
